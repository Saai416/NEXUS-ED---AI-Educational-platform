# Database Connection String
# Example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://postgres:your_password_here@your_db_host:5432/postgres

# Teacher Access Code (Required for Teacher Signup)
TEACHER_ACCESS_CODE=TEACHER_SECRET_2025

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone Credentials
PINECONE_KEY=your_pinecone_api_key_here
PINECONE_HOST=your_pinecone_host_url_here

# Neo4j Credentials
NEO4J_URI=neo4j+s://your_neo4j_uri_here
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
